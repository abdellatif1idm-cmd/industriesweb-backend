generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Submission {
  id            String   @id @default(uuid())
  source        String
  plan          String
  type          String?
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  email         String
  phone         String?
  fonction      String?
  entreprise    String?
  ville         String?
  localisation  String?
  interlocuteur String?
  message       String?
  read          Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("submissions")
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admins")
}

model PressAccreditation {
  id           String   @id @default(uuid())
  source       String
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  email        String
  phone        String
  media        String
  fonction     String
  website      String?
  coverage     String[]
  interview    Boolean
  pressCardUrl String?
  status       String   @default("pending")
  read         Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("press_accreditations")
}

view stats_view {
  submissions_total  BigInt?
  submissions_unread BigInt?
  press_total        BigInt?
  press_unread       BigInt?
  press_pending      BigInt?
  press_approved     BigInt?
  press_rejected     BigInt?
}
